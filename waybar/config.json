{
	"layer": "top",
	"position": "top",
	"height": 64,
	"//width": 1908,
	"modules-left": [
		"wlr/taskbar",
		"custom/weather",
		"custom/vpn",
		"custom/syncthing",
		"network"
	],
	"modules-center": [],
	"modules-right": [
		"cpu",
		"pulseaudio",
		"memory",
		"temperature",
		"disk",
		"custom/keyboard-layout",
		"battery",
		"tray",
		"clock#date",
		"clock#time",
		"custom/idling",
		"idle_inhibitor"
	],
	"wlr/taskbar": {
		"format": "{icon}",
		"icon-size": 14,
		"icon-theme": "Numix-Circle",
		"tooltip-format": "{title}",
		"on-click": "activate",
		"on-click-middle": "close"
	},
	"battery": {
		"interval": 10,
		"states": {
			"warning": 30,
			"critical": 15
		},
		"format": "яГз{icon}{capacity}%",
		"format-discharging": "{icon}{capacity}%",
		"format-icons": ["яЙГ ", "яЙД ", "яЙВ ", "яЙБ ", "яЙА "],
		"tooltip": true
	},
	"clock#time": {
		"interval": 1,
		"format": "{:%H:%M}",
		"tooltip": false
	},
	"clock#date": {
		"interval": 10,
		"format": "яБ│ {:%e %b %Y}",
		"tooltip-format": "{:%e %B %Y}"
	},
	"cpu": {
		"interval": 5,
		"format": "яТ╝ {usage}%({load}){min_frequency}/{avg_frequency}/{max_frequency}GHz",
		"states": {
			"warning": 70,
			"critical": 90
		}
	},
	"memory": {
		"interval": 5,
		"format": "яЛЫ {}%",
		"states": {
			"warning": 70,
			"critical": 90
		}
	},
	"disk": {
		"interval": 30,
		"format": "ґ░С╣ {percentage_used}%",
		"states": {
			"warning": 90,
			"critical": 95
		}
	},
	"network": {
		"interval": 5,
		"format-disconnected": "тЪа Disconnected",
		"format-ethernet": "яЮЦ  {ipaddr} тЖС{bandwidthUpBytes} тЖУ{bandwidthDownBytes}",
		"format-wifi": "яЗл {signalStrength}% \"{essid}\" тЖС{bandwidthUpBytes} тЖУ{bandwidthDownBytes}"
	},
	"pulseaudio": {
		"format": "{icon} {volume}%",
		"format-bluetooth": "{icon} яКФ{volume}%",
		"format-muted": "яАж",
		"format-icons": {
			"headphone": "яАе",
			"hands-free": "яЦР",
			"headset": "яАе",
			"phone": "яВХ",
			"portable": "яВХ",
			"car": "яЖ╣",
			"default": ["яАз", "яАи"]
		},
		"scroll-step": 1,
		"on-click": "pavucontrol"
	},
	"temperature": {
		"//hwmon-path-abs": "/sys/class/thermal/thermal_zone0/hwmon1",
		"//input-filename": "temp",
		"critical-threshold": 80,
		"interval": 5,
		"format": "{icon}{temperatureC}┬░C",
		"format-icons": ["яЛЛ", "яЛК", "яЛЙ", "яЛИ", "яЛИ"],
		"tooltip": true
	},
	"tray": {
		"icon-size": 15,
		"spacing": 10
	},
	"custom/vpn": {
		"format": "{}",
		"exec": "~/.config/waybar/bin/wireguard.sh",
		"return-type": "json",
		"interval": 5
	},
	"custom/idling": {
		"format": "{}",
		"exec": "~/.config/waybar/bin/idling.sh",
		"return-type": "json",
		"interval": 1
	},
	"idle_inhibitor": {
		"format": "{icon}",
		"format-icons": {
			"activated": "яБо",
			"deactivated": "яБ░"
		}
	},
	"custom/syncthing": {
		"format": "{}",
		"exec": "~/.config/waybar/bin/syncthing.sh",
		"return-type": "json",
		"interval": 1
	},
	"custom/weather": {
		"format": "{}",
		"exec": "~/.config/waybar/bin/weather.sh",
		"return-type": "json",
		"interval": 60
	}
}
